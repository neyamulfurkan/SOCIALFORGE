# =============================================================================
# SOCIALFORGE — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Neon serverless PostgreSQL connection string.
# Get this from your Neon project dashboard → Connection Details.
# The ?sslmode=require suffix is mandatory for Neon.
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET: Random 32+ character secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
#
# NEXTAUTH_URL: The canonical URL of your application.
# In development this is http://localhost:3000.
# In production set this to your actual domain, e.g. https://app.socialforge.io
# -----------------------------------------------------------------------------

NEXTAUTH_SECRET=your-32-character-minimum-random-secret-here
NEXTAUTH_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# UPSTASH REDIS
# -----------------------------------------------------------------------------
# Used for rate limiting, PlatformConfig caching, feature flag caching,
# and Messenger bot session state storage.
# Get both values from your Upstash Redis database dashboard → REST API.
# -----------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token


# -----------------------------------------------------------------------------
# CLOUDINARY
# -----------------------------------------------------------------------------
# Used for all image storage, transformation, and delivery.
# Get these from your Cloudinary dashboard → Settings → Access Keys.
#
# CLOUDINARY_UPLOAD_PRESET: Create a signed upload preset in your Cloudinary
# dashboard under Settings → Upload → Upload Presets.
#
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME must be the same value as
# CLOUDINARY_CLOUD_NAME — the NEXT_PUBLIC_ prefix exposes it to the browser
# for client-side Cloudinary URL construction.
# -----------------------------------------------------------------------------

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name


# -----------------------------------------------------------------------------
# RESEND
# -----------------------------------------------------------------------------
# Used for transactional emails: order confirmations, status updates,
# and business owner notifications.
# Get your API key from resend.com → API Keys.
# Free tier: 3,000 emails/month, 100/day.
# -----------------------------------------------------------------------------

RESEND_API_KEY=re_your_resend_api_key


# -----------------------------------------------------------------------------
# CRON SECURITY
# -----------------------------------------------------------------------------
# A secret string used to authenticate Vercel Cron requests to the two
# cron API routes: /api/cron/social-scheduler and /api/cron/social-insights.
# The cron routes check: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------

CRON_SECRET=your-cron-secret-random-string


# -----------------------------------------------------------------------------
# META / FACEBOOK
# -----------------------------------------------------------------------------
# META_APP_SECRET: Your Facebook App's App Secret.
# Used to verify the HMAC-SHA256 signature on incoming Messenger webhook
# POST requests (X-Hub-Signature-256 header) and to verify the webhook
# subscription GET request (hub.verify_token).
# Find this in your Meta Developer dashboard → Your App → Settings → Basic.
# -----------------------------------------------------------------------------

META_APP_SECRET=your-meta-facebook-app-secret


# -----------------------------------------------------------------------------
# STRIPE
# -----------------------------------------------------------------------------
# Used for card payment processing on the public store checkout.
# Stripe payment method is only shown when a business has configured their
# Stripe keys (stored per-business in BusinessConfig, not here).
#
# These platform-level keys are used for Stripe platform operations.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is exposed to the browser for
# Stripe.js / Stripe Elements initialization on the checkout page.
#
# STRIPE_WEBHOOK_SECRET: Get from Stripe dashboard → Developers → Webhooks
# after adding your endpoint (https://yourdomain.com/api/orders).
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret


# =============================================================================
# NOTE: GROQ API KEYS ARE NOT ENVIRONMENT VARIABLES
# =============================================================================
# The four Groq API keys used by SocialForge are intentionally absent from
# this file:
#
#   GROQ_KEY_CHATBOT     — website chatbot conversations
#   GROQ_KEY_DESCRIPTIONS — product description generation
#   GROQ_KEY_SOCIAL      — social media post caption generation
#   GROQ_KEY_MESSENGER   — Facebook Messenger bot intelligence
#
# These keys are stored in the database PlatformConfig table and managed
# exclusively from the Super Admin panel (Admin → Global Settings).
#
# This design enables:
#   1. Per-business key overrides without redeployment
#   2. Runtime key rotation without touching environment variables
#   3. White-label isolation — each business can supply their own keys
#
# After deploying, log in as the Super Admin and set all four keys via
# the admin panel before any AI features will function.
# =============================================================================